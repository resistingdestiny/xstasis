---
---

<footer class="border-t border-gray-800/30 mt-32">
  <div class="container mx-auto px-4 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
        <div>
          <p class="text-gray-400 text-lg font-light leading-relaxed italic">
            A moving archive of dancefloors. Documenting the pulse of underground culture.
          </p>
        </div>

        <div class="flex flex-col md:items-end gap-6">
          <div class="flex gap-8 text-sm">
            <a href="/rss.xml" class="text-gray-500 hover:text-neon-cyan transition-colors font-light">
              RSS
            </a>
          </div>
        </div>
      </div>

      <div class="h-px bg-gradient-to-r from-transparent via-gray-800/50 to-transparent mb-8"></div>

      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-700 text-xs font-light">
          &copy; {new Date().getFullYear()} xstasis.org
        </p>
        <p class="text-gray-700 text-xs font-light italic">
          The journey continues
        </p>
      </div>
    </div>
  </div>
</footer>
