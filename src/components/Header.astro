---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/run', label: 'The Run' },
  { href: '/clubs', label: 'Clubs' },
  { href: '/articles', label: 'Articles' },
  { href: '/about', label: 'About' },
];
---

<header class="sticky top-0 z-50 backdrop-blur-xl bg-gray-950/60 border-b border-gray-800/30">
  <nav class="container mx-auto px-4 py-6">
    <div class="flex items-center justify-between">
      <a href="/" class="text-2xl font-light tracking-tight hover:text-neon-cyan transition-colors">
        xstasis
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm font-light tracking-wide transition-all ${
              currentPath === item.href
                ? 'text-neon-cyan'
                : 'text-gray-400 hover:text-gray-200'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>

      <button
        id="search-trigger"
        class="p-2 text-gray-500 hover:text-neon-cyan transition-colors"
        aria-label="Open search"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <button
        id="mobile-menu-trigger"
        class="md:hidden p-2 text-gray-500 hover:text-neon-cyan transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden mt-6 space-y-4 pb-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`block text-lg font-light transition-all ${
            currentPath === item.href
              ? 'text-neon-cyan'
              : 'text-gray-400 hover:text-gray-200'
          }`}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const mobileMenuTrigger = document.getElementById('mobile-menu-trigger');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuTrigger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
