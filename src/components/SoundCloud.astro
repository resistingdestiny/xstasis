---
interface Props {
  url: string;
}

const { url } = Astro.props;
---

{url ? (
  <div class="soundcloud-embed my-8">
    <iframe
      width="100%"
      height="166"
      scrolling="no"
      frameborder="no"
      allow="autoplay"
      src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(url)}&color=%2300ffff&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true`}
    ></iframe>
  </div>
) : (
  <div class="bg-red-900/20 border border-red-500 p-4 rounded my-4">
    <p class="text-red-400">Missing SoundCloud URL</p>
  </div>
)}
