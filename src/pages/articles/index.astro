---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = await getCollection('articles');
const sortedArticles = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Articles - xstasis" description="Long-form explorations of club culture">
  <div class="container mx-auto px-4 py-12">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12">
        <h1 class="text-5xl font-bold mb-4 neon-text">Articles</h1>
        <p class="text-xl text-gray-400">
          Long-form explorations of the culture, the spaces, and the moments that define the underground.
        </p>
      </div>

      {sortedArticles.length > 0 ? (
        <div class="space-y-8">
          {sortedArticles.map((article) => (
            <article class="p-8 bg-gray-900/50 border border-gray-800 rounded-lg hover:border-neon-pink transition-all group">
              <a href={`/articles/${article.slug}`}>
                <time class="text-sm text-gray-500 font-mono mb-3 block">
                  {article.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <h2 class="text-3xl font-bold mb-4 group-hover:text-neon-pink transition-colors">
                  {article.data.title}
                </h2>
                <p class="text-gray-400 text-lg mb-4 leading-relaxed">
                  {article.data.summary}
                </p>
                {article.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {article.data.tags.map((tag) => (
                      <span class="text-xs px-3 py-1 bg-gray-800 text-gray-400 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-20 text-gray-500">
          <p>No articles yet. Stories coming soon...</p>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
